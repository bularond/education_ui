# Скопируй в .env и заполни: cp .env.example .env
# Разворачивание — на ДВУХ хостах. Каждому хосту нужен свой .env со своим набором.

# =========================================================================
# LLM-хост (edu.bularond.ru) — docker-compose.litellm.yml
# =========================================================================

# Ключ OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Мастер-ключ LiteLLM. Придумай длинную случайную строку, начни с "sk-".
# ВАЖНО: должен совпадать на обоих хостах — WebUI шлёт его как ключ доступа к LiteLLM.
# Пример генерации: openssl rand -hex 24  (и добавь префикс sk-)
LITELLM_MASTER_KEY=sk-change-me-to-a-long-random-string

# =========================================================================
# WebUI-хост (edu-ui.bularond.ru) — docker-compose.webui.yml
# =========================================================================

# Тот же LITELLM_MASTER_KEY, что и на LLM-хосте (обязательно совпадает).
# LITELLM_MASTER_KEY=sk-...

# Секрет сессий/JWT Open WebUI. Случайная строка. openssl rand -hex 32
WEBUI_SECRET_KEY=change-me-to-a-long-random-string

# (Необязательно) переопредели, если домены другие:
# LITELLM_BASE_URL=https://edu.bularond.ru/v1
# WEBUI_URL=https://edu-ui.bularond.ru
